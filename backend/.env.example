# Server port (optional, default: 8000)
PORT=8000

# MySQL database connection string (required by Prisma)
# Format: mysql://username:password@host:port/database_name
DATABASE_URL=mysql://root:root@localhost:3306/membership_db

# JWT signing secret (required)
# Please use a long, random string in production
JWT_SECRET=your-jwt-secret-key-change-me-in-production

# Node environment (development | production)
# When set to "development", error stack traces will be returned in API responses
NODE_ENV=development
