generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  password      String
  role          String   @default("ADMIN")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  operatedTxs   PointsTransaction[]
  operatedMemberTags MemberTag[]
  operatedTagHistories TagBindingHistory[]
  operatedCoupons Coupon[]
  operatedCouponIssueBatches CouponIssueBatch[]
  operatedNotificationTemplates NotificationTemplate[]
  operatedNotifications Notification[]
  receivedNotifications NotificationRecipient[]
  operatedExportTasks ExportTask[]
  operatedWorkOrders WorkOrder[]
  operatedExchangeRecords ExchangeRecord[]
  operatedBirthdayWishTemplates BirthdayWishTemplate[]
  operatedBirthdayPointsRules BirthdayPointsRule[]
  operatedBirthdayCareConfigs BirthdayCareConfig[]
  operatedBirthdayCareRecords BirthdayCareRecord[]

  @@map("users")
}

model Member {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String   @unique
  email         String?
  level         MemberLevel @default(NORMAL)
  status        MemberStatus @default(ACTIVE)
  points        Int      @default(0)
  frozenPoints  Int      @default(0) @map("frozen_points")
  birthday      Int?     @map("birthday")
  birthdayMonth Int?     @map("birthday_month")
  birthdayDay   Int?     @map("birthday_day")
  calendarType  CalendarType @default(SOLAR) @map("calendar_type")
  joinDate      DateTime @default(now())
  updatedAt     DateTime @updatedAt
  transactions  PointsTransaction[]
  memberTags    MemberTag[]
  tagHistories  TagBindingHistory[]
  memberCoupons MemberCoupon[]
  workOrders    WorkOrder[]
  signInRecords SignInRecord[]
  exchangeRecords ExchangeRecord[]
  birthdayCareRecords BirthdayCareRecord[]

  @@map("members")
}

enum CalendarType {
  SOLAR
  LUNAR
}

enum MemberLevel {
  NORMAL
  SILVER
  GOLD
  PLATINUM
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PointsChangeType {
  ADD
  DEDUCT
  FREEZE
  UNFREEZE
  EXPIRE
  REVERSE
}

enum PointsReasonType {
  MANUAL_ADJUST
  MALL_EXCHANGE
  SIGN_IN_REWARD
  ACTIVITY_BONUS
  ORDER_EARN
  EXPIRE_CLEAR
  FREEZE_OP
  UNFREEZE_OP
  REVERSE_OP
  REGISTER_REWARD
  BIRTHDAY_GIFT
  OTHER
}

model PointsTransaction {
  id            Int               @id @default(autoincrement())
  serialNo      String            @unique @map("serial_no")
  memberId      Int               @map("member_id")
  member        Member            @relation(fields: [memberId], references: [id], onDelete: Restrict)
  changeType    PointsChangeType  @map("change_type")
  changeValue   Int               @map("change_value")
  balanceBefore Int               @map("balance_before")
  balanceAfter  Int               @map("balance_after")
  reasonType    PointsReasonType  @map("reason_type")
  bizOrderNo    String?           @map("biz_order_no")
  bizOrderType  String?           @map("biz_order_type")
  operatorId    Int?              @map("operator_id")
  operator      User?             @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  remark        String?
  reverseOfId   Int?              @map("reverse_of_id")
  reverseOf     PointsTransaction? @relation("ReverseRelation", fields: [reverseOfId], references: [id], onDelete: SetNull)
  reversedBy    PointsTransaction[] @relation("ReverseRelation")
  birthdayCareRecords BirthdayCareRecord[]
  createdAt     DateTime          @default(now()) @map("created_at")

  @@index([memberId])
  @@index([serialNo])
  @@index([changeType])
  @@index([reasonType])
  @@index([bizOrderNo])
  @@index([createdAt])
  @@map("points_transactions")
}

enum AuditActionType {
  MEMBER_CREATE
  MEMBER_UPDATE
  MEMBER_DELETE
  POINTS_ADJUST
  POINTS_FREEZE
  POINTS_UNFREEZE
  USER_CREATE
  USER_UPDATE
  USER_DELETE
  AUTH_LOGIN
  AUTH_LOGOUT
  COUPON_ISSUE
  COUPON_CREATE
  COUPON_UPDATE
  COUPON_DELETE
  COUPON_STATUS_CHANGE
  COUPON_REDEEM
  COUPON_REFUND
  BLACKLIST_ADD
  BLACKLIST_REMOVE
  DATA_EXPORT
  SYSTEM_CONFIG
  TRANSACTION_REVERSE
  BATCH_OPERATION
  TAG_GROUP_CREATE
  TAG_GROUP_UPDATE
  TAG_GROUP_DELETE
  TAG_CREATE
  TAG_UPDATE
  TAG_DELETE
  MEMBER_TAG_BIND
  MEMBER_TAG_UNBIND
  TAG_RULE_APPLY
  BIRTHDAY_CONFIG_UPDATE
  BIRTHDAY_CARE_EXECUTE
  BIRTHDAY_CARE_BATCH
  OTHER
}

enum AuditEntityType {
  MEMBER
  USER
  POINTS_TRANSACTION
  COUPON
  BLACKLIST
  SYSTEM
  AUDIT_CONFIG
  TAG_GROUP
  TAG
  MEMBER_TAG
  BIRTHDAY_WISH_TEMPLATE
  BIRTHDAY_POINTS_RULE
  BIRTHDAY_CARE_RECORD
}

model TagGroup {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  tags        Tag[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("tag_groups")
}

enum TagRuleOperator {
  EQ
  NE
  GT
  GTE
  LT
  LTE
  BETWEEN
  CONTAINS
  IN
}

enum TagRuleField {
  POINTS
  LEVEL
  STATUS
  JOIN_DATE
  LAST_ACTIVE_DATE
  CONSUME_COUNT
  CONSUME_AMOUNT
}

enum TagRuleLogic {
  AND
  OR
}

model Tag {
  id            Int       @id @default(autoincrement())
  name          String
  color         String    @default("#409EFF")
  description   String?
  groupId       Int?      @map("group_id")
  group         TagGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  isMutuallyExclusive Boolean @default(false) @map("is_mutually_exclusive")
  uniqueInGroup Boolean   @default(false) @map("unique_in_group")
  autoRuleEnabled Boolean @default(false) @map("auto_rule_enabled")
  ruleLogic     TagRuleLogic? @map("rule_logic")
  ruleConditions Json?    @map("rule_conditions")
  memberTags    MemberTag[]
  tagHistories  TagBindingHistory[]
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([groupId])
  @@map("tags")
}

enum MemberTagSource {
  MANUAL
  AUTO_RULE
  BATCH
}

model MemberTag {
  id         Int              @id @default(autoincrement())
  memberId   Int              @map("member_id")
  member     Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tagId      Int              @map("tag_id")
  tag        Tag              @relation(fields: [tagId], references: [id], onDelete: Cascade)
  source     MemberTagSource  @default(MANUAL)
  operatorId Int?             @map("operator_id")
  operator   User?            @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  remark     String?
  createdAt  DateTime         @default(now()) @map("created_at")

  @@unique([memberId, tagId])
  @@index([memberId])
  @@index([tagId])
  @@map("member_tags")
}

model TagBindingHistory {
  id         Int              @id @default(autoincrement())
  memberId   Int              @map("member_id")
  member     Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tagId      Int              @map("tag_id")
  tag        Tag              @relation(fields: [tagId], references: [id], onDelete: Cascade)
  action     String           // BIND or UNBIND
  source     MemberTagSource  @default(MANUAL)
  operatorId Int?             @map("operator_id")
  operator   User?            @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  remark     String?
  createdAt  DateTime         @default(now()) @map("created_at")

  @@index([memberId])
  @@index([tagId])
  @@index([createdAt])
  @@map("tag_binding_histories")
}

enum AuditSensitivityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CouponType {
  FULL_REDUCTION
  DISCOUNT
  POINTS_EXCHANGE
}

enum CouponStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ENDED
}

enum CouponScope {
  ALL
  PRODUCT
  CATEGORY
}

enum MemberCouponStatus {
  CLAIMED
  LOCKED
  REDEEMED
  RETURNED
  EXPIRED
}

enum IssueTargetType {
  SPECIFIC
  LEVEL
  TAG
}

model Coupon {
  id                Int                @id @default(autoincrement())
  name              String
  type              CouponType
  value             Decimal            @db.Decimal(10, 2)
  minConsume        Decimal            @default(0) @db.Decimal(10, 2) @map("min_consume")
  pointsCost        Int?               @map("points_cost")
  applicableLevels  Json?              @map("applicable_levels")
  scope             CouponScope        @default(ALL)
  scopeIds          Json?              @map("scope_ids")
  validFrom         DateTime?          @map("valid_from")
  validTo           DateTime?          @map("valid_to")
  validDays         Int?               @map("valid_days")
  totalQuantity     Int                @map("total_quantity")
  claimedQuantity   Int                @default(0) @map("claimed_quantity")
  redeemedQuantity  Int                @default(0) @map("redeemed_quantity")
  perUserLimit      Int                @default(1) @map("per_user_limit")
  stackable         Boolean            @default(false)
  shelfStatus       Boolean            @default(true) @map("shelf_status")
  status            CouponStatus       @default(DRAFT)
  description       String?
  operatorId        Int?               @map("operator_id")
  operator          User?              @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  memberCoupons     MemberCoupon[]
  issueBatches      CouponIssueBatch[]
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("coupons")
}

model MemberCoupon {
  id            Int                @id @default(autoincrement())
  couponId      Int                @map("coupon_id")
  coupon        Coupon             @relation(fields: [couponId], references: [id], onDelete: Restrict)
  memberId      Int                @map("member_id")
  member        Member             @relation(fields: [memberId], references: [id], onDelete: Restrict)
  code          String             @unique
  status        MemberCouponStatus @default(CLAIMED)
  orderNo       String?            @map("order_no")
  batchId       Int?               @map("batch_id")
  issueBatch    CouponIssueBatch?  @relation(fields: [batchId], references: [id], onDelete: SetNull)
  claimedAt     DateTime           @default(now()) @map("claimed_at")
  lockedAt      DateTime?          @map("locked_at")
  redeemedAt    DateTime?          @map("redeemed_at")
  returnedAt    DateTime?          @map("returned_at")
  expiredAt     DateTime?          @map("expired_at")
  remark        String?

  @@index([couponId])
  @@index([memberId])
  @@index([status])
  @@index([claimedAt])
  @@map("member_coupons")
}

model CouponIssueBatch {
  id              Int              @id @default(autoincrement())
  couponId        Int              @map("coupon_id")
  coupon          Coupon           @relation(fields: [couponId], references: [id], onDelete: Restrict)
  targetType      IssueTargetType  @default(SPECIFIC) @map("target_type")
  targetIds       Json             @map("target_ids")
  scheduledAt     DateTime?        @map("scheduled_at")
  expireReminder  Boolean          @default(true) @map("expire_reminder")
  totalIssued     Int              @default(0) @map("total_issued")
  operatorId      Int?             @map("operator_id")
  operator        User?            @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  memberCoupons   MemberCoupon[]
  createdAt       DateTime         @default(now()) @map("created_at")

  @@index([couponId])
  @@index([createdAt])
  @@map("coupon_issue_batches")
}

enum AuditResultStatus {
  SUCCESS
  FAILURE
  PARTIAL
}

model AuditLog {
  id                 BigInt              @id @default(autoincrement())
  operatorId         Int?                @map("operator_id")
  operatorUsername   String?             @map("operator_username")
  actionType         AuditActionType     @map("action_type")
  entityType         AuditEntityType     @map("entity_type")
  entityId           String?             @map("entity_id")
  beforeSnapshot     Json?               @map("before_snapshot")
  afterSnapshot      Json?               @map("after_snapshot")
  requestIp          String?             @map("request_ip")
  userAgent          String?             @map("user_agent") @db.Text
  requestPath        String?             @map("request_path")
  requestMethod      String?             @map("request_method")
  requestParams      Json?               @map("request_params")
  remark             String?             @db.Text
  sensitivityLevel   AuditSensitivityLevel @default(MEDIUM) @map("sensitivity_level")
  resultStatus       AuditResultStatus   @default(SUCCESS) @map("result_status")
  errorMessage       String?             @map("error_message") @db.Text
  durationMs         Int?                @map("duration_ms")
  createdAt          DateTime            @default(now()) @map("created_at")

  @@index([operatorId])
  @@index([actionType])
  @@index([entityType, entityId])
  @@index([sensitivityLevel])
  @@index([resultStatus])
  @@index([createdAt])
  @@map("audit_logs")
}

model AuditConfig {
  id                 Int                 @id @default(autoincrement())
  actionType         AuditActionType     @unique @map("action_type")
  enabled            Boolean             @default(true)
  sensitivityLevel   AuditSensitivityLevel @default(MEDIUM) @map("sensitivity_level")
  description        String?
  updatedAt          DateTime            @updatedAt @map("updated_at")
  updatedBy          Int?                @map("updated_by")

  @@map("audit_configs")
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  URGENT
}

enum NotificationTargetType {
  SINGLE_USER
  ROLE
  TAG
  ALL
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationStatus {
  DRAFT
  SCHEDULED
  SENT
  ARCHIVED
}

model NotificationTemplate {
  id          Int              @id @default(autoincrement())
  name        String
  type        NotificationType @default(INFO)
  title       String
  content     String           @db.Text
  variables   Json?
  isSystem    Boolean          @default(false) @map("is_system")
  operatorId  Int?             @map("operator_id")
  operator    User?            @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  notifications Notification[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([type])
  @@index([isSystem])
  @@map("notification_templates")
}

model Notification {
  id              Int                    @id @default(autoincrement())
  type            NotificationType       @default(INFO)
  title           String
  content         String                 @db.Text
  priority        NotificationPriority   @default(MEDIUM)
  targetType      NotificationTargetType @default(ALL) @map("target_type")
  targetIds       Json?                  @map("target_ids")
  status          NotificationStatus     @default(DRAFT)
  scheduledAt     DateTime?              @map("scheduled_at")
  expiredAt       DateTime?              @map("expired_at")
  sentAt          DateTime?              @map("sent_at")
  templateId      Int?                   @map("template_id")
  template        NotificationTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateVariables Json?                @map("template_variables")
  operatorId      Int?                   @map("operator_id")
  operator        User?                  @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  recipients      NotificationRecipient[]
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  @@index([type])
  @@index([priority])
  @@index([status])
  @@index([targetType])
  @@index([scheduledAt])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationRecipient {
  id              Int           @id @default(autoincrement())
  notificationId  Int           @map("notification_id")
  notification    Notification  @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId          Int           @map("user_id")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  isRead          Boolean       @default(false) @map("is_read")
  readAt          DateTime?     @map("read_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@unique([notificationId, userId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notification_recipients")
}

enum ExportType {
  MEMBERS
  POINTS_TRANSACTIONS
  COUPON_CLAIMS
  WORK_ORDERS
  SIGN_IN_RECORDS
  EXCHANGE_RECORDS
}

enum ExportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

model ExportTask {
  id               Int          @id @default(autoincrement())
  exportType       ExportType   @map("export_type")
  status           ExportStatus @default(PENDING)
  fields           Json         @map("fields")
  filters          Json?        @map("filters")
  dateRange        Json?        @map("date_range")
  sortBy           String?      @map("sort_by")
  sortOrder        String?      @default("desc") @map("sort_order")
  filterSummary    String?      @map("filter_summary")
  filePath         String?      @map("file_path")
  fileName         String?      @map("file_name")
  fileSize         Int?         @map("file_size")
  downloadCount    Int          @default(0) @map("download_count")
  errorMessage     String?      @map("error_message") @db.Text
  operatorId       Int?         @map("operator_id")
  operator         User?        @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  operatorUsername String?      @map("operator_username")
  expiredAt        DateTime?    @map("expired_at")
  completedAt      DateTime?    @map("completed_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([exportType])
  @@index([status])
  @@index([operatorId])
  @@index([createdAt])
  @@index([expiredAt])
  @@map("export_tasks")
}

model ExportFieldConfig {
  id           Int        @id @default(autoincrement())
  exportType   ExportType @unique @map("export_type")
  adminFields  Json       @map("admin_fields")
  userFields   Json       @map("user_fields")
  updatedBy    Int?       @map("updated_by")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("export_field_configs")
}

enum WorkOrderStatus {
  PENDING
  PROCESSING
  RESOLVED
  CLOSED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model WorkOrder {
  id          Int              @id @default(autoincrement())
  title       String
  description String?          @db.Text
  status      WorkOrderStatus  @default(PENDING)
  priority    WorkOrderPriority @default(MEDIUM)
  memberId    Int              @map("member_id")
  member      Member           @relation(fields: [memberId], references: [id], onDelete: Restrict)
  operatorId  Int?             @map("operator_id")
  operator    User?            @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  resolvedAt  DateTime?        @map("resolved_at")
  closedAt    DateTime?        @map("closed_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  @@index([status])
  @@index([priority])
  @@index([memberId])
  @@index([createdAt])
  @@map("work_orders")
}

model SignInRecord {
  id        Int      @id @default(autoincrement())
  memberId  Int      @map("member_id")
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  points    Int      @default(0)
  signDate  DateTime @default(now()) @map("sign_date")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([memberId, signDate])
  @@index([memberId])
  @@index([signDate])
  @@map("sign_in_records")
}

model ExchangeRecord {
  id          Int      @id @default(autoincrement())
  memberId    Int      @map("member_id")
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Restrict)
  itemName    String   @map("item_name")
  pointsCost  Int      @map("points_cost")
  quantity    Int      @default(1)
  orderNo     String   @unique @map("order_no")
  status      String   @default("COMPLETED")
  operatorId  Int?     @map("operator_id")
  operator    User?    @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  remark      String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([memberId])
  @@index([status])
  @@index([createdAt])
  @@map("exchange_records")
}

enum CareChannel {
  SMS
  WECHAT
  EMAIL
  IN_APP
  MANUAL
}

enum CareResult {
  SUCCESS
  FAILED
  PARTIAL
  SKIPPED
}

model BirthdayWishTemplate {
  id          Int          @id @default(autoincrement())
  level       MemberLevel  @unique
  title       String
  content     String       @db.Text
  isEnabled   Boolean      @default(true) @map("is_enabled")
  operatorId  Int?         @map("operator_id")
  operator    User?        @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([level])
  @@map("birthday_wish_templates")
}

model BirthdayPointsRule {
  id                  Int          @id @default(autoincrement())
  level               MemberLevel  @unique
  points              Int          @default(0)
  preventDuplicate    Boolean      @default(true) @map("prevent_duplicate")
  isEnabled           Boolean      @default(true) @map("is_enabled")
  operatorId          Int?         @map("operator_id")
  operator            User?        @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  @@index([level])
  @@map("birthday_points_rules")
}

model BirthdayCareConfig {
  id                  Int      @id @default(autoincrement())
  remindDaysBefore    Int      @default(3) @map("remind_days_before")
  autoSendEnabled     Boolean  @default(false) @map("auto_send_enabled")
  defaultChannel      CareChannel @default(SMS) @map("default_channel")
  operatorId          Int?     @map("operator_id")
  operator            User?    @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("birthday_care_configs")
}

model BirthdayCareRecord {
  id                 Int          @id @default(autoincrement())
  memberId           Int          @map("member_id")
  member             Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  birthdayYear       Int          @map("birthday_year")
  channel            CareChannel  @map("channel")
  templateId         Int?         @map("template_id")
  wishContent        String?      @db.Text @map("wish_content")
  pointsGiven        Int          @default(0) @map("points_given")
  transactionId      Int?         @map("transaction_id")
  transaction        PointsTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  operatorId         Int?         @map("operator_id")
  operator           User?        @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  result             CareResult   @default(SUCCESS)
  errorMessage       String?      @db.Text @map("error_message")
  remark             String?
  createdAt          DateTime     @default(now()) @map("created_at")

  @@unique([memberId, birthdayYear])
  @@index([memberId])
  @@index([birthdayYear])
  @@index([channel])
  @@index([result])
  @@index([createdAt])
  @@map("birthday_care_records")
}
